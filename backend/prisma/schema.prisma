datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id                String  @id @default(uuid())
  name              String
  sku               String
  country           String?
  cost              Float
  productWeight     Float
  supplierTaxPoint  Float
  supplierInvoice   String
  sellerCouponType  String  @default("fixed")
  sellerCoupon      Float   @default(0)
  sellerCouponPlatformRatio Float @default(0)
  adROI             Float   @default(15)
  sites             String[] @default([])
  userId            String
  user              User    @relation(fields: [userId], references: [id])
  templates         ProfitTemplate[]
}

model FinanceRecord {
  id          String   @id @default(uuid())
  date        DateTime
  type        String
  amount      Float
  category    String
  description String
  accountId   String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model InventoryItem {
  id              String  @id @default(uuid())
  name            String
  sku             String
  currentStock    Int
  stockOfficial   Int
  stockThirdParty Int
  inTransit       Int
  dailySales      Float
  leadTime        Int
  replenishCycle  Int
  costPerUnit     Float
  userId          String
  user            User    @relation(fields: [userId], references: [id])
}

model WarehouseMapping {
  id                    String  @id @default(uuid())
  officialWarehouseId   String?
  thirdPartyWarehouseId String?
  sku                   String
  type                  String
  userId                String
  user                  User    @relation(fields: [userId], references: [id])
}

model SkuGroup {
  id        String   @id @default(uuid())
  groupName String
  skus      String[]
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model RestockRecord {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  items     Json
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model ProfitTemplate {
  id        String   @id @default(uuid())
  type      String   @default("profit")
  name      String
  country   String
  platform  String?
  data      Json
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
}

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  password    String
  displayName String
  phone       String?
  email       String?
  avatar      String?
  role        String   @default("viewer")
  permissions String[] @default([])
  parentId    String?
  parent      User?    @relation("SubAccounts", fields: [parentId], references: [id])
  children    User[]   @relation("SubAccounts")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products       Product[]
  financeRecords  FinanceRecord[]
  inventoryItems  InventoryItem[]
  warehouseMappings WarehouseMapping[]
  skuGroups       SkuGroup[]
  restockRecords  RestockRecord[]
  profitTemplates ProfitTemplate[]
}
